# Required keys for local testing only.
# Generate fresh values before using outside a throwaway environment.
ENCRYPTION_KEY=replace-with-random-32-char-hex
AUTH_SECRET=replace-with-random-base64-secret

# Postgres
POSTGRES_PASSWORD=infisical
POSTGRES_USER=infisical
POSTGRES_DB=infisical
DB_CONNECTION_URI=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379

# URL exposed by the backend service.
# This compose file maps host port 8088 to container port 8080 to avoid clashing
# with other local services that may already use port 80.
SITE_URL=http://localhost:8088

# Optional SMTP/email settings
SMTP_HOST=
SMTP_PORT=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional telemetry
OTEL_TELEMETRY_COLLECTION_ENABLED=false
OTEL_EXPORT_TYPE=prometheus
