# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
SOURCE_DB_NAME=vectadb
SOURCE_COLLECTION_NAME=ai_targets
DESTINATION_DB_NAME=log_samples
TRACKING_DB_NAME=loggingtracker
TRACKING_COLLECTION_NAME=logging_tracks

# ── Sampling behavior ─────────────────────────────────────────────────────────
# SAMPLE_MODE: head | tail | both
SAMPLE_MODE=both
# Lines captured per file (can be overridden per-target in the UI)
SAMPLE_LINE_COUNT=50

# ── Service execution ─────────────────────────────────────────────────────────
# RUN_MODE: once | periodic
RUN_MODE=periodic
POLL_INTERVAL_SECS=300
CONCURRENCY=4
SSH_TIMEOUT_SECS=15

# ── REST API ──────────────────────────────────────────────────────────────────
API_PORT=8080

# ── Prometheus metrics ────────────────────────────────────────────────────────
METRICS_PORT=9090

# ── Remote file discovery ─────────────────────────────────────────────────────
REMOTE_MAX_DEPTH=3
# Max files per target directory (can be overridden per-target in the UI)
REMOTE_MAX_FILES_PER_TARGET=100
REMOTE_FIND_PATTERNS=*.log,*.out,*.txt

# ── Preprocessing pipeline ────────────────────────────────────────────────────
PREPROCESSING_ENABLED=true
PREPROCESSING_AGENTIC_THRESHOLD=0.02
PREPROCESSING_MAX_SCHEMA_LINES=200

# ── LLM Classification ───────────────────────────────────────────────────────
CLASSIFICATION_ENABLED=false
ANTHROPIC_API_KEY=sk-ant-...
CLASSIFICATION_MODEL=claude-haiku-4-5-20251001
CLASSIFICATION_SIGNAL_THRESHOLD=0.05
CLASSIFICATION_MAX_PER_CYCLE=10
CLASSIFICATION_MAX_OUTPUT_TOKENS=1024
# API format: "anthropic" (default) or "openai" (any OpenAI-compatible provider)
CLASSIFICATION_API_FORMAT=anthropic
# Base URL — leave empty to use provider default. Examples:
#   http://localhost:11434   → Ollama
#   https://openrouter.ai/api → OpenRouter
#   https://api.groq.com/openai → Groq
CLASSIFICATION_API_BASE_URL=

# ── Notifications / alerting ─────────────────────────────────────────────────
# Set NOTIFICATION_ENABLED=true and configure at least one destination.
NOTIFICATION_ENABLED=false
# Minimum severity to trigger a notification: normal | info | warning | critical
NOTIFICATION_SEVERITY_THRESHOLD=critical
# Slack incoming-webhook URL (leave empty to skip Slack)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Generic HTTP endpoint — receives a JSON POST with the full classification (leave empty to skip)
WEBHOOK_URL=https://your-endpoint.example.com/logflayer
# Optional shared secret for HMAC-SHA256 payload signing (X-Logflayer-Signature header)
WEBHOOK_SECRET=your-secret-here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIRECTORY=./logs
LOG_FILE_BASE_NAME=logflayer
LOG_MAX_FILE_SIZE_BYTES=10485760
LOG_MAX_FILES=10

# ── Docker UI port ────────────────────────────────────────────────────────────
UI_PORT=3000
