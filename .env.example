# MongoDB source and destination
MONGODB_URI=mongodb://localhost:27017
SOURCE_DB_NAME=logflayer
SOURCE_COLLECTION_NAME=ai_targets
DESTINATION_DB_NAME=log_samples

# Sampling behavior
SAMPLE_MODE=both
SAMPLE_LINE_COUNT=50

# Service execution
RUN_MODE=once
POLL_INTERVAL_SECS=300
CONCURRENCY=4
SSH_TIMEOUT_SECS=15

# Remote discovery
REMOTE_MAX_DEPTH=3
REMOTE_MAX_FILES_PER_TARGET=100
REMOTE_FIND_PATTERNS=*.log,*.out,*.txt

# Logging
LOG_LEVEL=info
LOG_DIRECTORY=./logs
LOG_FILE_BASE_NAME=logflyer
LOG_MAX_FILE_SIZE_BYTES=10485760
LOG_MAX_FILES=10
